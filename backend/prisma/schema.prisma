generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
}

model User {
  id               String   @id @default(uuid())
  authProviderId   String   @unique @map("auth_provider_id") // Trỏ tới UID của Supabase Auth
  email            String   @unique
  fullName         String   @map("full_name")
  avatarUrl        String?  @map("avatar_url")
  role             Role     @default(STUDENT)
  createdAt        DateTime @default(now()) @map("created_at")

  progress UserProgress[]

  @@map("users")
}

model Course {
  id              String   @id @default(uuid())
  title           String
  description     String?
  level           String
  coverImageUrl   String?  @map("cover_image_url")
  createdAt       DateTime @default(now()) @map("created_at")

  lessonSets LessonSet[]

  @@map("courses")
}

model LessonSet {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  title       String
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]

  @@map("lesson_sets")
}

enum LessonType {
  MAIN_AUDIO
  VOCABULARY
  MINI_STORY
  POV
}

model Lesson {
  id              String     @id @default(uuid())
  lessonSetId     String     @map("lesson_set_id")
  type            LessonType
  title           String
  audioUrl        String?    @map("audio_url")
  transcriptJson  Json?      @map("transcript_json") // Lưu mảng các câu thoại và thời gian
  orderIndex      Int        @default(0) @map("order_index")
  createdAt       DateTime   @default(now()) @map("created_at")

  lessonSet LessonSet      @relation(fields: [lessonSetId], references: [id])
  progress  UserProgress[]

  @@map("lessons")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model UserProgress {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  lessonId      String         @map("lesson_id")
  status        ProgressStatus @default(NOT_STARTED)
  lastPosition  Int            @default(0) @map("last_position") // Số giây đang nghe dở
  updatedAt     DateTime       @updatedAt @map("updated_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId]) // Một user chỉ có 1 tiến độ cho 1 bài học
  @@map("user_progress")
}
